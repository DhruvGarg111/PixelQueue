APP_ENV=development
LOG_LEVEL=INFO

POSTGRES_USER=vision
POSTGRES_PASSWORD=vision
POSTGRES_DB=annotation_platform
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=annotation-artifacts

API_PORT=8000
ML_SERVICE_PORT=8002
FRONTEND_PORT=5173
FLOWER_PORT=5555
PROMETHEUS_PORT=9090
WORKER_METRICS_PORT=9101

DATABASE_URL=postgresql+psycopg2://vision:vision@postgres:5432/annotation_platform
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
ML_SERVICE_URL=http://ml-service:8002
DEFAULT_AUTO_LABEL_PROVIDER=yolo_seg

MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_PRESIGN_EXPIRY_SECONDS=900
MAX_IMAGE_BYTES=20971520
ALLOWED_IMAGE_CONTENT_TYPES=image/png,image/jpeg,image/jpg,image/webp

JWT_SECRET_KEY=replace-with-a-secure-random-value
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_MINUTES=10080

CORS_ORIGIN=*
