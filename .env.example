APP_ENV=development
LOG_LEVEL=INFO

POSTGRES_USER=vision
POSTGRES_PASSWORD=vision
POSTGRES_DB=annotation_platform
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=annotation-artifacts

API_PORT=8000
ML_SERVICE_PORT=8002
FRONTEND_PORT=5173
VITE_API_URL=

DATABASE_URL=postgresql+psycopg2://vision:vision@postgres:5432/annotation_platform
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
ML_SERVICE_URL=http://ml-service:8002
DEFAULT_AUTO_LABEL_PROVIDER=yolo_seg

MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_PRESIGN_EXPIRY_SECONDS=900
MAX_IMAGE_BYTES=20971520
ALLOWED_IMAGE_CONTENT_TYPES=image/png,image/jpeg,image/jpg,image/webp

JWT_SECRET_KEY=replace-with-a-secure-random-value
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_MINUTES=10080
ACCESS_TOKEN_COOKIE_NAME=pixelqueue_access
REFRESH_TOKEN_COOKIE_NAME=pixelqueue_refresh
ACCESS_TOKEN_COOKIE_PATH=/api
REFRESH_TOKEN_COOKIE_PATH=/api/v1/auth
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
