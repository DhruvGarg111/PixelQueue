import React from "react";
import { useAnnotationStore } from "../store/annotationStore";
import { Button } from "./ui/Button";
import { Input } from "./ui/Input";
import { Badge } from "./ui/Badge";
import { cn } from "../lib/utils";

const AnnotationItem = React.memo(({ item, idx, isSelected, selectAnnotation, updateAnnotation, removeAnnotation }) => {
    return (
        <div
            onClick={() => selectAnnotation(item.id)}
            className={cn(
                "p-4 rounded cursor-pointer transition-colors duration-150 border overflow-hidden",
                isSelected
                    ? "bg-primary/10 border-primary"
                    : "bg-background-dark border-primary/20 hover:border-primary/50"
            )}
        >
            <div className="flex justify-between items-start mb-3">
                <div className="flex items-center gap-2">
                    <span className={cn("material-symbols-outlined text-[16px]", isSelected ? "text-primary" : "text-primary/50")}>tag</span>
                    <strong className={cn(
                        "font-mono text-sm uppercase tracking-wider",
                        isSelected ? "text-primary font-bold" : "text-slate-300 font-bold"
                    )}>
                        EN-{String(idx + 1).padStart(3, '0')}
                    </strong>
                </div>
                <Badge variant="secondary" className="text-[9px] uppercase tracking-wider py-0.5 px-1.5 h-auto rounded font-bold">
                    {item.geometry.type}
                </Badge>
            </div>

            <Input
                value={item.label}
                onChange={(e) => updateAnnotation(item.id, { label: e.target.value })}
                onClick={(e) => e.stopPropagation()}
                placeholder="Enter classification"
                className="mb-3 h-8 text-xs bg-background-dark border-primary/30 text-primary font-bold focus:border-primary"
            />

            <div className="flex flex-wrap gap-x-2 gap-y-1 font-mono text-[10px] text-primary/70 mb-4 font-bold">
                <span className="uppercase">{item.source}</span>
                <span className="text-primary/30">|</span>
                <span className={cn(
                    "uppercase",
                    item.status === "approved" ? "text-green-500" :
                        item.status === "rejected" ? "text-red-500" : "text-yellow-500"
                )}>
                    {item.status}
                </span>
                {item.confidence != null && (
                    <>
                        <span className="text-primary/30">|</span>
                        <span>CONF: {item.confidence.toFixed(2)}</span>
                    </>
                )}
            </div>

            <Button
                variant="outline"
                size="sm"
                disabled={!isSelected}
                className={cn(
                    "w-full h-8 text-[10px] tracking-wider uppercase font-bold border-transparent transition-colors duration-150",
                    !isSelected && "hidden", // hide when not selected
                    isSelected && "border-red-500/30 text-red-500 hover:bg-red-500/10 hover:border-red-500"
                )}
                onClick={(e) => {
                    e.stopPropagation();
                    removeAnnotation(item.id);
                }}
            >
                <span className="material-symbols-outlined text-[14px] mr-1.5">delete</span> Delete Entity
            </Button>
        </div>
    );
});

export function AnnotationSidebar() {
    const annotations = useAnnotationStore((s) => s.annotations);
    const selectedId = useAnnotationStore((s) => s.selectedId);
    const selectAnnotation = useAnnotationStore((s) => s.selectAnnotation);
    const updateAnnotation = useAnnotationStore((s) => s.updateAnnotation);
    const removeAnnotation = useAnnotationStore((s) => s.removeAnnotation);

    return (
        <aside className="flex flex-col h-full overflow-hidden bg-background-dark/80 border-l border-primary/20 relative z-10 w-80 flex-shrink-0">
            <div className="flex-shrink-0 p-5 border-b border-primary/20 bg-background-dark">
                <p className="text-[10px] font-mono uppercase tracking-widest text-primary/50 mb-1 font-bold">Inspector</p>
                <div className="flex justify-between items-center">
                    <h3 className="text-base font-bold font-display text-slate-100 tracking-tight m-0">
                        Entities
                    </h3>
                    <Badge variant="secondary" className="font-mono">{annotations.length}</Badge>
                </div>
                <p className="text-xs text-slate-400 mt-2">Modify labels and manage valid regions.</p>
            </div>

            <div className="flex-grow overflow-y-auto flex flex-col gap-3 p-4 bg-[#0A1112] custom-scrollbar">
                {annotations.map((item, idx) => {
                    const isSelected = selectedId === item.id;
                    return (
                        <AnnotationItem
                            key={item.id}
                            item={item}
                            idx={idx}
                            isSelected={isSelected}
                            selectAnnotation={selectAnnotation}
                            updateAnnotation={updateAnnotation}
                            removeAnnotation={removeAnnotation}
                        />
                    );
                })}

                {annotations.length === 0 && (
                    <div className="flex flex-col items-center justify-center text-center p-8 border border-dashed border-primary/30 rounded bg-primary/5 text-primary/70 gap-3 mt-4">
                        <div className="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary/50">
                            <span className="material-symbols-outlined text-[20px] mx-0">tag</span>
                        </div>
                        <div className="text-sm font-bold text-slate-100 font-mono uppercase tracking-widest">No entities active.</div>
                        <div className="text-xs text-slate-400">Draw a region on the canvas.</div>
                    </div>
                )}
            </div>
        </aside>
    );
}
